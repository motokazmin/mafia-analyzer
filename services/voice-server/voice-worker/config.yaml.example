# Скопируйте в config.yaml рядом с voice-worker или укажите путь в VOICE_SERVER_CONFIG_PATH.
# Переменные окружения перекрывают значения из файла.

api_key: barchik
max_file_size_mb: 500

# Явный путь к SQLite; если не задан — см. use_google_drive и локальный data/
# db_path: /path/to/voice_registry.sqlite
use_google_drive: false

# Пусто / auto / не указывать — авто (CUDA если есть). Иначе: cuda | cpu
# device: cuda

whisper_model: large-v2
# hf_token лучше задавать через переменную окружения HF_TOKEN
# hf_token: ""

enable_voice_learning: true

voice_threshold_preset: balanced
# При необходимости переопределите числа (как раньше через env THRESHOLD_*):
# threshold_confident_match: 0.75
# threshold_soft_match: 0.60
# threshold_force_new: 0.45
# similarity_update_min: 0.65
# pending_match_threshold: 0.55
# split_distance_threshold: 0.22

calibration_window: 300.0
max_extra_slots: 2
min_speaker_duration: 1.0
pending_max_chunks: 3
embedding_buffer_size: 10
min_long_segment_sec: 2.0

embedding_backend: wespeaker

hdbscan_min_cluster_size: 3
split_max_clusters: 4
sub_rebuild_every: 10
segment_embeddings_max: 100
max_sub_centroids: 6
sub_min_cluster_size: 3
